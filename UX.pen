                  "type": "text",
                  "id": "B7uyw",
                  "name": "li2",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "2. Implement Markdown dependency scanner",
                  "lineHeight": 1.6,
                  "fontFamily": "Outfit",
                  "fontSize": 15
                },
                {
                  "type": "text",
                  "id": "QXnfr",
                  "name": "li3",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "3. Build agent API surface with scoped credentials",
                  "lineHeight": 1.6,
                  "fontFamily": "Outfit",
                  "fontSize": 15
                },
