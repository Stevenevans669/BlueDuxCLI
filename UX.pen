                  "type": "text",
                  "id": "owzPL",
                  "name": "li1",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "1. Finalize share link format and password encryption",
                  "lineHeight": 1.6,
                  "fontFamily": "Outfit",
                  "fontSize": 15
                },
