                  "fontFamily": "Outfit",
                  "fontSize": 15
                },
                {
                  "type": "text",
                  "id": "1ImKa",
                  "name": "h2",
                  "fill": "$--text-primary",
                  "content": "Architecture Decisions",
                  "fontFamily": "Cormorant Garamond",
                  "fontSize": 24,
                  "fontWeight": "500"
                },
                {
                  "type": "text",
                  "id": "LmjL7",
                  "name": "p2",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "We opted for content-addressed blob storage with immutable snapshots. This approach provides natural deduplication and a clean versioning model without the complexity of git-style branching.",
                  "lineHeight": 1.6,
                  "fontFamily": "Outfit",
                  "fontSize": 15
                },
                {
                  "type": "text",
                  "id": "uyjQ0",
                  "name": "h3",
                  "fill": "$--text-primary",
                  "content": "Next Steps",
                  "fontFamily": "Cormorant Garamond",
                  "fontSize": 24,
                  "fontWeight": "500"
                },
